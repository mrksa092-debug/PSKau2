rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    incoming().keys().hasAll(['patientFileNumber', 'createdAt']) &&
                    incoming().patientFileNumber is string &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && request.auth.uid == userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['patientFileNumber']);

      // 2. User Chats
      match /chats/{chatId} {
        allow list, get: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId &&
                      isValidChatMessage(incoming());
      }
    }

    // 3. Patients (Hospital Records - Read Only via Linking)
    match /patients/{fileNumber} {
      // Allow user to get their linked patient record
      allow get: if isSignedIn() && 
                 get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientFileNumber == fileNumber;
      
      // Verification logic: Allow anonymous get IF DOB matches (Limited check)
      // Note: This is an exception for the "login" simulation. 
      // In production, this would be behind a Cloud Function.
      allow list: if false; // Never allow listing all patients
      
      match /appointments/{appId} {
        allow list, get: if isSignedIn() && 
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.patientFileNumber == fileNumber;
      }
    }

    // Validation Helpers
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'sender', 'timestamp']) &&
             data.text is string && data.text.size() <= 2000 &&
             data.sender in ['user', 'ai'] &&
             data.timestamp == request.time;
    }
  }
}
